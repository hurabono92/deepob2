// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum BoardType {
  BUSINESS_NEWS
  NOTICE
  ACTIVITY_NEWS
  ALBUM
}

model Post {
  id           Int       @id @default(autoincrement())
  board        BoardType
  title        String
  content      String
  thumbnailUrl String?
  authorName   String    @default("관리자")
  viewCount    Int       @default(0)
  published    Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  images       PostImage[]

  @@index([board, createdAt])
}

// 게시물 첨부 사진 여러 장 — 관리자 페이지에서 추가/삭제/순서 변경 가능
model PostImage {
  id        Int      @id @default(autoincrement())
  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  imageUrl  String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([postId, order])
}

model HeroSlide {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([order])
}

// 단일 슬롯 이미지(예: 조직도 배너 사진) — key로 구분해 관리자 페이지에서 교체 가능
model SiteImage {
  key       String   @id
  imageUrl  String
  updatedAt DateTime @updatedAt
}

// 단일 슬롯 텍스트(예: 메인 화면 문구) — key로 구분해 관리자 페이지에서 수정 가능
model SiteText {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
